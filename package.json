{
  "name": "@danieljvdm/agent-skills",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Portable agent skills and a sync CLI for project-local harness opt-in.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danieljvdm/agent-skills.git"
  },
  "license": "MIT",
  "bin": {
    "agent-skills": "./bin/agent-skills.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": "./schema/agent-skills.schema.json",
    "./schema/agent-skills.schema.json": "./schema/agent-skills.schema.json"
  },
  "files": [
    "agent-skills.example.jsonc",
    "bin/",
    "schema/",
    "skills/",
    "src/"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "sync": "./bin/agent-skills.mjs sync",
    "sync:dry": "./bin/agent-skills.mjs sync --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.79",
    "effect": "4.0.0-beta.79",
    "jsonc-parser": "3.3.1",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
